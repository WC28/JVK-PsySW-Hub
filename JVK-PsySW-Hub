<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>JVK PsySW Hub — One-Page Pitch</title>
  <meta name="description" content="PSW Hub Pitch Page — one-page animated, scroll-driven" />


  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&family=Cormorant+Garamond:wght@500;600;700&display=swap');

    :root{
      --ink: #0a0f1a;
      --deep:#0d1e35;

      --teal: #0d9e8e;
      --teal2:#0bc5b0;

      --gold:#4a8443;
      --gold2:#f0c96a;

      --white:#ffffff;
      --fog: rgba(255,255,255,.65);
      --mist: rgba(255,255,255,.06);
      --line: rgba(255,255,255,.12);

      --shadow: 0 18px 60px rgba(0,0,0,.55);
      --r: 24px;

      --max: 1100px;

      --navTopPad: 18px;
      --navSidePad: 60px;
      --navHeightOffset: 86px;
    }

    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      font-family: 'Sarabun', system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      color: var(--white);
      background: var(--ink);
      overflow-x:hidden;
    }

    /* --- background scene --- */
    .bg-scene{
      position:fixed;
      inset:0;
      z-index:-2;
      background:
        radial-gradient(ellipse 70% 60% at 50% 10%, rgba(13,158,142,.20) 0%, transparent 55%),
        radial-gradient(ellipse 45% 45% at 15% 70%, rgba(240,201,106,.12) 0%, transparent 60%),
        radial-gradient(ellipse 45% 45% at 85% 75%, rgba(11,197,176,.14) 0%, transparent 60%),
        linear-gradient(180deg, #060a12 0%, #0a0f1a 45%, #070b13 100%);
      filter: saturate(1.05);
    }
    .bg-grid{
      position:fixed;
      inset:0;
      z-index:-1;
      background-image:
        linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
      background-size: 64px 64px;
      mask-image: radial-gradient(ellipse at center, black 35%, transparent 75%);
      opacity:.55;
      pointer-events:none;
    }
    .orb{
      position:fixed;
      width: 520px; height: 520px;
      border-radius: 50%;
      filter: blur(90px);
      opacity:.55;
      z-index:-1;
      pointer-events:none;
      animation: float 8s ease-in-out infinite;
    }
    .orb.one{left:-160px; top:-140px; background: rgba(13,158,142,.22); animation-delay:0s;}
    .orb.two{right:-220px; bottom:-200px; background: rgba(240,201,106,.16); animation-delay:-4s;}
    @keyframes float{
      0%,100%{transform: translateY(0)}
      50%{transform: translateY(-28px)}
    }

    /* --- reading progress bar --- */
    .reading-bar{
      position:fixed;
      top:0; left:0;
      height:3px;
      width:0%;
      background: linear-gradient(90deg, var(--teal2), var(--gold2));
      z-index:1000;
      box-shadow: 0 0 18px rgba(11,197,176,.22);
      pointer-events:none;
    }

    /* --- nav --- */
    nav{
      position:fixed;
      top:0; left:0; right:0;
      z-index:500;
      padding: var(--navTopPad) var(--navSidePad);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 18px;
      background: linear-gradient(to bottom, rgba(10,15,26,.95), transparent);
      backdrop-filter: blur(8px);
      transition: .25s ease;
    }
    .nav-logo{
      display:flex;
      align-items:center;
      gap: 10px;
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 700;
      letter-spacing:.5px;
      user-select:none;
    }
    .nav-logo .dot{
      width: 10px; height:10px;
      border-radius:50%;
      background: var(--teal);
      box-shadow: 0 0 12px rgba(13,158,142,.55);
      animation: pulse 2s infinite;
    }
    @keyframes pulse{
      0%,100%{opacity:1; transform: scale(1)}
      50%{opacity:.65; transform: scale(1.25)}
    }

    .nav-links{
      display:flex;
      gap: 26px;
      align-items:center;
      flex-wrap:wrap;
    }
    .nav-links a{
      color: var(--fog);
      text-decoration:none;
      font-size: 13px;
      letter-spacing:.5px;
      transition:.2s;
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
    }
    .nav-links a:hover{
      color: var(--teal2);
      border-bottom-color: rgba(11,197,176,.35);
    }

    .nav-cta{
      padding: 9px 22px;
      border: 1.5px solid var(--teal);
      border-radius: 30px;
      background: transparent;
      color: var(--teal2);
      font-family: 'Sarabun', sans-serif;
      font-size: 13px;
      font-weight: 600;
      cursor:pointer;
      letter-spacing:.3px;
      transition:.25s ease;
    }
    .nav-cta:hover{
      background: rgba(13,158,142,.14);
      color: #fff;
    }

    /* --- sections --- */
    section{
      position:relative;
    }
    .section-wrap{
      max-width: var(--max);
      margin: 0 auto;
      padding: 100px 40px;
    }
    .section-label{
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--teal2);
      margin-bottom: 12px;
      font-weight: 600;
    }
    .section-title{
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(32px, 5vw, 50px);
      font-weight: 700;
      line-height: 1.15;
      margin-bottom: 16px;
      letter-spacing:.2px;
    }
    .section-desc{
      font-size: 16px;
      color: rgba(255,255,255,.6);
      line-height: 1.8;
      max-width: 620px;
      margin: 0 auto;
    }
    .divider{
      width: 60px;
      height: 3px;
      background: linear-gradient(90deg, var(--teal2), var(--gold2));
      border-radius: 2px;
      margin: 0 auto 20px;
    }

    /* --- reveal animation --- */
    .reveal{
      opacity:0;
      transform: translateY(24px);
      transition: .75s ease;
    }
    .reveal.visible{
      opacity:1;
      transform: translateY(0);
    }
    .reveal-delay-1{transition-delay:.08s}
    .reveal-delay-2{transition-delay:.16s}
    .reveal-delay-3{transition-delay:.24s}
    .reveal-delay-4{transition-delay:.32s}

    /* --- HERO --- */
    #hero{
      min-height: 100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      padding: 120px 40px 80px;
      overflow:hidden;
    }
    .hero-bg{
      position:absolute;
      inset:0;
      background:
        radial-gradient(ellipse 80% 60% at 50% 40%, rgba(13,158,142,.18) 0%, transparent 70%),
        radial-gradient(ellipse 40% 40% at 80% 80%, rgba(240,201,106,.10) 0%, transparent 60%),
        var(--ink);
      z-index:-1;
    }
    .hero-grid{
      position:absolute;
      inset:0;
      background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
      z-index:-1;
    }

    .hero-content{
      max-width: 860px;
      position:relative;
      z-index:2;
    }
    .hero-badge{
      display:inline-flex;
      align-items:center;
      gap: 8px;
      background: rgba(13,158,142,.15);
      border: 1px solid rgba(13,158,142,.30);
      padding: 7px 18px;
      border-radius: 30px;
      font-size: 12px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--teal2);
      margin-bottom: 28px;
      animation: fadeUp .8s .05s ease both;
    }
    .spark{
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--teal2), var(--gold2));
      box-shadow: 0 0 12px rgba(240,201,106,.18);
    }

    .hero-title{
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(48px, 8vw, 90px);
      font-weight: 700;
      line-height: 1.05;
      margin-bottom: 24px;
      animation: fadeUp .8s .15s ease both;
    }
    .hero-title .teal{color: var(--teal2)}
    .hero-title .gold{color: var(--gold2)}

    .hero-sub{
      font-size: clamp(15px, 2vw, 18px);
      line-height: 1.8;
      color: rgba(255,255,255,.65);
      max-width: 580px;
      margin: 0 auto 36px;
      animation: fadeUp .8s .30s ease both;
    }

    .hero-buttons{
      display:flex;
      gap: 14px;
      justify-content:center;
      flex-wrap:wrap;
      margin-bottom: 30px;
      animation: fadeUp .8s .45s ease both;
    }
    .btn-hero{
      padding: 14px 32px;
      border-radius: 50px;
      font-size: 14px;
      font-weight: 700;
      cursor:pointer;
      transition:.25s ease;
      letter-spacing:.3px;
      font-family: 'Sarabun', sans-serif;
    }
    .btn-hero.primary{
      border:none;
      color:#fff;
      background: linear-gradient(135deg, var(--teal), var(--teal2));
      box-shadow: 0 4px 24px rgba(13,158,142,.40);
    }
    .btn-hero.primary:hover{transform: translateY(-2px); box-shadow: 0 8px 32px rgba(13,158,142,.50);}
    .btn-hero.outline{
      background: transparent;
      color: var(--white);
      border: 1.5px solid rgba(255,255,255,.25);
    }
    .btn-hero.outline:hover{border-color: var(--gold2); color: var(--gold2); transform: translateY(-2px);}

    .hero-stats{
      display:flex;
      justify-content:center;
      gap: 40px;
      flex-wrap:wrap;
      margin-top: 18px;
      padding-top: 40px;
      border-top: 1px solid var(--line);
      animation: fadeUp .8s .65s ease both;
    }
    .h-stat{text-align:center; min-width: 120px}
    .h-stat .num{
      font-family: 'Cormorant Garamond', serif;
      font-size: 36px;
      font-weight: 700;
      color: var(--teal2);
      display:block;
    }
    .h-stat .lbl{
      font-size: 12px;
      letter-spacing: .5px;
      color: rgba(255,255,255,.55);
      margin-top: 4px;
    }

    @keyframes fadeUp{
      from{opacity:0; transform: translateY(24px)}
      to{opacity:1; transform: translateY(0)}
    }

    /* --- PROBLEM --- */
    #problem{background: var(--ink);}
    .problem-grid{
      display:grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      margin-top: 50px;
    }
    .problem-card{
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 20px;
      padding: 28px;
      position:relative;
      overflow:hidden;
      transition:.3s;
    }
    .problem-card:before{
      content:'';
      position:absolute;
      inset:0;
      background: linear-gradient(135deg, rgba(13,158,142,.08) 0%, transparent 60%);
      opacity:0;
      transition:.3s;
    }
    .problem-card:hover{border-color: rgba(13,158,142,.30); transform: translateY(-4px);}
    .problem-card:hover:before{opacity:1}
    .prob-icon{
      font-size: 32px;
      margin-bottom: 14px;
      opacity:.95;
    }
    .prob-title{
      font-size: 17px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .prob-desc{
      font-size: 14px;
      line-height: 1.7;
      color: rgba(255,255,255,.55);
    }
    .prob-tag{
      display:inline-block;
      margin-top: 12px;
      padding: 4px 12px;
      background: rgba(212,168,67,.15);
      border: 1px solid rgba(212,168,67,.30);
      color: var(--gold2);
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
    }

    /* --- SOLUTION --- */
    #solution{
      background: linear-gradient(180deg, rgba(13,158,142,.06) 0%, transparent 50%);
      border-top: 1px solid var(--line);
    }
    .solution-hero{
      background: linear-gradient(135deg, #0d1e35, #0a2228);
      border: 1px solid rgba(13,158,142,.20);
      border-radius: var(--r);
      padding: 40px;
      text-align:center;
      margin: 36px auto 40px;
      position:relative;
      overflow:hidden;
      box-shadow: var(--shadow);
    }
    .solution-hero:before{
      content:'';
      position:absolute;
      right:-20px;
      top:50%;
      transform: translateY(-50%);
      width: 240px;
      height: 240px;
      border-radius: 50%;
      background: radial-gradient(circle at center, rgba(240,201,106,.16), transparent 60%);
      filter: blur(2px);
      opacity:.65;
      pointer-events:none;
    }
    .solution-hero .big{
      font-family: 'Cormorant Garamond', serif;
      font-size: 26px;
      font-weight: 700;
      margin-bottom: 12px;
      position:relative;
      z-index:1;
    }
    .solution-hero .desc{
      font-size: 15px;
      color: rgba(255,255,255,.65);
      line-height: 1.8;
      max-width: 600px;
      margin: 0 auto;
      position:relative;
      z-index:1;
    }
    .pill{
      display:inline-flex;
      gap: 8px;
      align-items:center;
      font-size: 12px;
      padding: 6px 12px;
      border-radius: 999px;
      margin: 6px 6px 0 0;
      font-weight: 600;
      border: 1px solid rgba(255,255,255,.10);
      position:relative;
      z-index:1;
      user-select:none;
    }
    .pill-teal{background: rgba(13,158,142,.12); color: rgba(255,255,255,.85); border-color: rgba(13,158,142,.28)}
    .pill-gold{background: rgba(240,201,106,.12); color: rgba(255,255,255,.85); border-color: rgba(240,201,106,.24)}

    .features-grid{
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 10px;
    }
    .feat-card{
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 20px;
      padding: 24px;
      transition:.3s;
    }
    .feat-card:hover{transform: translateY(-4px); border-color: rgba(255,255,255,.14);}
    .feat-icon{
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size: 18px;
      margin-bottom: 14px;
    }
    .feat-icon.teal{background: rgba(13,158,142,.20);}
    .feat-icon.gold{background: rgba(212,168,67,.20);}
    .feat-icon.purple{background: rgba(124,92,191,.20);}
    .feat-icon.blue{background: rgba(58,123,213,.20);}
    .feat-icon.green{background: rgba(39,174,96,.20);}
    .feat-icon.red{background: rgba(224,82,82,.20);}

    .feat-title{
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .feat-desc{
      font-size: 13px;
      color: rgba(255,255,255,.55);
      line-height: 1.6;
    }

    /* --- FLOW --- */
    #flow{
      background: var(--ink);
      border-top: 1px solid var(--line);
    }
    .flow-steps{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap: 0;
      margin-top: 50px;
      position:relative;
    }
    .flow-steps:before{
      content:'';
      position:absolute;
      top: 28px;
      left: 28px;
      right: 28px;
      height: 2px;
      background: linear-gradient(90deg, var(--teal2), var(--gold2));
      z-index:0;
      opacity:.9;
    }
    .flow-step{
      flex: 1;
      text-align:center;
      position:relative;
      z-index:1;
      padding: 0 12px;
    }
    .flow-num{
      width: 34px;
      height: 34px;
      border-radius: 50%;
      margin: 0 auto 10px;
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.16);
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight: 800;
      color: var(--white);
    }
    .flow-title{
      font-weight: 800;
      margin-bottom: 6px;
      font-size: 13.5px;
      letter-spacing:.2px;
    }
    .flow-desc{
      font-size: 12.5px;
      color: rgba(255,255,255,.55);
      line-height: 1.55;
      max-width: 180px;
      margin: 0 auto;
    }

    /* --- IMPACT --- */
    #impact{
      background: linear-gradient(180deg, rgba(13,158,142,.06) 0%, transparent 55%);
      border-top: 1px solid var(--line);
    }
    .impact-grid{
      display:grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-top: 42px;
    }
    .impact-card{
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 20px;
      padding: 24px 22px;
      text-align:center;
      transition:.3s;
      overflow:hidden;
      position:relative;
    }
    .impact-card:hover{transform: translateY(-4px); border-color: rgba(13,158,142,.25);}
    .impact-num{
      font-family: 'Cormorant Garamond', serif;
      font-size: 46px;
      font-weight: 700;
      background: linear-gradient(135deg, var(--teal2), var(--gold2));
      -webkit-background-clip:text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 6px;
      line-height: 1;
    }
    .impact-lbl{
      font-weight: 800;
      margin-bottom: 6px;
      letter-spacing:.2px;
    }
    .impact-desc{
      font-size: 13px;
      color: rgba(255,255,255,.55);
      line-height: 1.6;
    }

    /* --- VISION --- */
    #vision{
      background: var(--ink);
      border-top: 1px solid var(--line);
    }
    .vision-quote{
      margin: 30px auto 20px;
      max-width: 820px;
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 22px;
      padding: 26px 24px;
      text-align:center;
    }
    .vision-quote .highlight{color: var(--teal2); font-weight: 800;}
    .vision-quote .highlight2{color: var(--gold2); font-weight: 800;}
    .vision-author{
      margin-top: 10px;
      color: rgba(255,255,255,.55);
      font-size: 13px;
      letter-spacing:.2px;
    }
    .roadmap{
      margin-top: 60px;
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }
    .road-card{
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 20px;
      padding: 22px;
      position:relative;
      overflow:hidden;
      transition:.3s;
    }
    .road-card:hover{transform: translateY(-4px); border-color: rgba(240,201,106,.22);}
    .road-phase{
      font-size: 12px;
      letter-spacing: 2px;
      color: rgba(255,255,255,.65);
      margin-bottom: 8px;
      text-transform: uppercase;
    }
    .road-title{
      font-weight: 800;
      margin-bottom: 10px;
      font-size: 15px;
    }
    .road-list{
      list-style: none;
      display:grid;
      gap: 8px;
    }
    .road-list li{
      color: rgba(255,255,255,.60);
      font-size: 13px;
      line-height: 1.6;
      padding-left: 16px;
      position:relative;
    }
    .road-list li:before{
      content:'';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--teal2), var(--gold2));
      position:absolute;
      left: 0;
      top: .55em;
      box-shadow: 0 0 12px rgba(11,197,176,.12);
    }

    /* --- CTA --- */
    #cta{
      background: linear-gradient(180deg, rgba(13,158,142,.06) 0%, transparent 55%);
      border-top: 1px solid var(--line);
    }
    .cta-inner{
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: var(--r);
      padding: 44px 30px 28px;
      text-align:center;
      position:relative;
      overflow:hidden;
      box-shadow: var(--shadow);
    }
    .cta-title{
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(34px, 5vw, 54px);
      font-weight: 700;
      line-height: 1.15;
      margin-bottom: 14px;
    }
    .cta-desc{
      color: rgba(255,255,255,.62);
      font-size: 15px;
      line-height: 1.8;
      max-width: 760px;
      margin: 0 auto 22px;
    }
    .cta-buttons{
      display:flex;
      justify-content:center;
      gap: 12px;
      flex-wrap:wrap;
      margin-bottom: 22px;
    }
    .contact-row{
      display:flex;
      justify-content:center;
      gap: 12px;
      flex-wrap:wrap;
      margin-top: 12px;
    }
    .contact-item{
      width: min(220px, 100%);
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 18px;
      padding: 14px 14px;
      text-align:left;
      display:grid;
      grid-template-columns: 34px 1fr;
      column-gap: 10px;
      align-items:center;
    }
    .contact-item .icon{
      width: 34px;
      height: 34px;
      border-radius: 12px;
      background: rgba(13,158,142,.14);
      border: 1px solid rgba(13,158,142,.22);
      display:flex;
      align-items:center;
      justify-content:center;
      color: rgba(255,255,255,.92);
      font-weight: 800;
      font-size: 12px;
    }
    .contact-item .label{
      color: rgba(255,255,255,.55);
      font-size: 12px;
      margin-bottom: 2px;
    }
    .contact-item .val{
      font-size: 13px;
      font-weight: 700;
      letter-spacing:.2px;
      color: rgba(255,255,255,.88);
      word-break: break-word;
    }

    footer{
      padding: 24px 40px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      border-top: 1px solid rgba(255,255,255,.08);
      color: rgba(255,255,255,.55);
      font-size: 12px;
    }
